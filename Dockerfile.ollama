# Ollama self-hosted LLM service for MaraAI
#
# Build:  docker build -f Dockerfile.ollama -t maraai-ollama .
# Run:    docker run -p 11434:11434 -e OLLAMA_MODEL=llama3.2:1b maraai-ollama
#
# Railway: create a second service, point it at this Dockerfile.
# Internal URL for MaraAI service: http://ollama:11434

FROM ollama/ollama:latest

# Expose Ollama port (Railway will also inject $PORT via env)
EXPOSE 11434

# Default small model — override with OLLAMA_MODEL env var
ENV OLLAMA_MODEL=llama3.2:1b

# Whether to pull the model at container startup (set to "false" to skip and
# avoid long cold-start times when the model is already on a persistent volume)
ENV OLLAMA_PULL_ON_START=true

# Bind to all interfaces so Railway's internal networking can reach us
ENV OLLAMA_HOST=0.0.0.0

# Entrypoint: start Ollama server, then optionally pull the model
COPY ollama-entrypoint.sh /ollama-entrypoint.sh
RUN chmod +x /ollama-entrypoint.sh

ENTRYPOINT ["/ollama-entrypoint.sh"]
