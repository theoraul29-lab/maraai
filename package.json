{
  "name": "maraai",
  "version": "1.0.0",
  "description": "MaraAI — Full-stack AI platform (Node.js server + React frontend)",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "npm run build:frontend && if [ -d functions ]; then npm run build:functions; else echo 'No functions folder'; fi",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build:functions": "if [ -d functions ]; then cd functions && npm install && npm run build; else echo 'No functions directory, skipping.'; fi",
    "start": "tsx server/index.ts",
    "start:backend": "tsx server/index.ts",
    "deploy": "firebase deploy --project maraai-488fb",
    "deploy:hosting": "firebase deploy --only hosting --project maraai-488fb",
    "deploy:functions": "firebase deploy --only functions --project maraai-488fb",
    "logs": "firebase functions:log --follow --project maraai-488fb",
    "smoke:runtime": "node scripts/smoke-runtime.mjs"
  },
  "dependencies": {
    "@genkit-ai/googleai": "^1.28.0",
    "@openrouter/sdk": "^0.12.3",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.5.1",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "genkit": "^1.16.1",
    "memoizee": "^0.4.15",
    "multer": "^2.1.1",
    "openid-client": "^6.8.2",
    "passport": "^0.7.0",
    "stripe": "^17.7.0",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/connect-sqlite3": "^0.9.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/memoizee": "^0.4.11",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/passport": "^1.0.16",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.15.0",
    "typescript": "~5.5.0",
    "vite": "^8.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
