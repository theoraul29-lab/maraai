{
  "type": "module",
  "name": "maraai-task-manager",
  "version": "1.0.0",
  "description": "A task manager web application with add, delete, and complete features.",
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "20.19.0",
    "npm": "10.8.2"
  },
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -k -n backend,frontend -c green,cyan \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "tsx server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "start:backend": "tsx server/index.ts",
    "preview": "vite preview",
    "autonomy:report": "node script/autonomy-report.cjs",
    "autonomy:deps": "node script/safe-deps.cjs",
    "autonomy:deps:apply": "node script/safe-deps.cjs --apply",
    "autonomy:run": "npm run autonomy:report && npm run autonomy:deps",
    "smoke:runtime": "node script/smoke-runtime.cjs",
    "smoke:learning": "node script/smoke-learning.cjs"
  },
  "keywords": [
    "task",
    "manager",
    "webapp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^2.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "memoizee": "^0.4.17",
    "nodemailer": "^8.0.1",
    "openai": "^4.104.0",
    "openid-client": "^6.8.2",
    "passport": "^0.7.0",
    "pg": "^8.20.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^4.0.0"
  }
}
