# App runtime
NODE_ENV=production
PORT=5000

# Sessions/auth
AUTH_MODE=local
SESSION_SECRET=replace-with-a-long-random-secret

# SQLite database path
# Railway with volume: sqlite:///data/maraai.sqlite
# Local default: sqlite:///./maraai.sqlite
DATABASE_URL=sqlite:///./maraai.sqlite

# Optional AI provider settings
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# Optional scheduler controls
MARA_LEARNING_AUTORUN=true
MARA_LEARNING_INTERVAL_HOURS=8
