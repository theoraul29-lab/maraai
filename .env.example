# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Required in production. In dev a random one is generated if unset.
SESSION_SECRET=

# ─── Auth ───────────────────────────────────────────────────────────────────
# `local` bypasses OAuth and is the dev default. Use `oauth` only when you
# have the identity provider configured.
AUTH_MODE=local

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite path. On Railway, mount a Volume at /data and use:
#   sqlite:////data/maraai.sqlite
# Four slashes = absolute path (/data/...). Three slashes = relative to CWD.
DATABASE_URL=sqlite:///./maraai.sqlite

# ─── AI — Chat (conversații cu userii) ──────────────────────────────────────
# Cheia folosită exclusiv pentru chat-ul live cu userii.
# Obţine o cheie de la https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── AI — Brain (autonom: learning, research, growth engineer) ───────────────
# Cheie separată pentru brain-ul autonom. Dacă nu e setată, brain-ul
# foloseşte ANTHROPIC_API_KEY ca fallback (compatibil cu instalaţii existente).
ANTHROPIC_BRAIN_API_KEY=

# Optional. Model folosit pentru AMBELE canale (default: claude-sonnet-4-6).
# Poţi seta ANTHROPIC_BRAIN_MODEL separat dacă vrei un model diferit pentru brain.
ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BRAIN_MODEL=claude-haiku-4-5-20251001

# Optional. Max tokens per răspuns (default: 1024).
ANTHROPIC_MAX_TOKENS=1024

# Optional. Timeout în ms (default: 120000).
ANTHROPIC_TIMEOUT_MS=120000

# ─── Web Search (optional — rezultate reale pentru Mara Brain research) ──────
# Cheie gratuită de la https://serper.dev — 2500 interogări/lună gratuite.
# Fără ea, brain-ul foloseşte DuckDuckGo (mai slab) sau doar LLM.
SERPER_API_KEY=

# ─── Ollama (opţional — self-hosted, fără cost per token) ───────────────────
# Lasă gol dacă nu rulezi Ollama. Când e setat, router-ul încearcă Ollama
# DOAR pentru chat (brain-ul merge direct pe Claude indiferent).
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# ─── Mara Brain ─────────────────────────────────────────────────────────────
# Enable the autonomous brain cycle (learning, research, self-reflection).
# Set to "true" in production once at least one AI provider is configured
# (OLLAMA_BASE_URL or ANTHROPIC_API_KEY). With Ollama as the primary
# provider every cycle costs zero per-token, so a tighter interval is
# perfectly fine.
# ─── Sistem plăți & lansare ──────────────────────────────────────────────────
# false = VIP blocat. Se activează automat când isLaunched()=true SAU
# când numărul de useri activi în 24h >= ACTIVE_USERS_THRESHOLD.
PAYMENT_SYSTEM_ACTIVE=false
ACTIVE_USERS_THRESHOLD=100

PROCESS_AI_TASKS=false

# Optional. Override the brain cycle interval (default: 2h = 7200000 ms).
# Tuning suggestions:
#   30 min →  1800000   (aggressive — only on a fast Ollama or with Anthropic)
#    1 h   →  3600000   (sweet spot when running on a desktop Ollama)
#    2 h   →  7200000   (default — balances learning with Anthropic cost)
#    6 h   → 21600000   (conservative — keeps token spend predictable)
# BRAIN_CYCLE_INTERVAL_MS=3600000

# Optional. Mara auto-publishes a "Mara AI Insight" post in the creator feed
# every BRAIN_SELF_POST_INTERVAL_MS (default 4h = 14400000 ms). Set
# BRAIN_SELF_POST_ENABLED=false to keep autonomous learning on but stop the
# auto-marketing posts.
# BRAIN_SELF_POST_ENABLED=true
# BRAIN_SELF_POST_INTERVAL_MS=14400000

# ─── Mara Learning Engine ───────────────────────────────────────────────────
# Phase 4.5 of the brain cycle: per-module growth analyzers (You / Reels /
# Missions / Writers / Creators / VIP). Each analyzer proposes concrete growth
# levers that require admin approval in /admin/brain.
# Set to "false" to disable JUST the module analyzers without touching the
# rest of the brain cycle.
MARA_LEARNING_ENABLED=true

# Hard cap on Claude calls made by autonomous learning (per rolling 24h).
# User-facing chat is never throttled by this. Default: 100.
MARA_LEARNING_MAX_CALLS_PER_DAY=100

# ─── Admin access ───────────────────────────────────────────────────────────
# Comma-separated list of user ids with admin access to /admin/brain, etc.
ADMIN_USER_IDS=

# Comma-separated list of admin emails (case-insensitive). Use this in addition
# to or instead of ADMIN_USER_IDS — emails survive DB resets (ephemeral SQLite
# without a mounted Volume), so you stay admin even after a redeploy wipes
# user ids. Example: ADMIN_EMAILS=you@example.com,ops@example.com
ADMIN_EMAILS=

# ─── Email delivery (Resend) ─────────────────────────────────────────────────
# Required for password-reset emails, OTP delivery, and welcome emails.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# "From" address shown to recipients. Must be a verified domain in Resend.
# Default: Mara <noreply@hellomara.net>
EMAIL_FROM=

# Base URL used when building links inside emails (e.g. /reset-password?token=…).
# Default: https://hellomara.net
FRONTEND_URL=

# ─── OAuth — Google ─────────────────────────────────────────────────────────
# Both values come from https://console.cloud.google.com/apis/credentials →
# "OAuth 2.0 Client IDs" → Web application. Leave empty to disable the
# Google sign-in button (the backend endpoint returns a redirect to
# `/?oauth_error=oauth_not_configured`).
#
# Authorized redirect URIs in Google Cloud Console MUST include, in order:
#   https://hellomara.net/api/auth/google/callback
#   http://localhost:5000/api/auth/google/callback
#   http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Override the base URL used when building the redirect_uri passed
# to Google. Defaults to the current request's origin (works behind Railway's
# reverse proxy because we honour x-forwarded-proto / x-forwarded-host).
# OAUTH_REDIRECT_BASE=https://hellomara.net

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. https://maraai.app,http://localhost:5173).
# Leave empty in dev to allow any origin.
CORS_ORIGINS=

# ─── OAuth — Facebook ───────────────────────────────────────────────────────
# Both values come from https://developers.facebook.com → Your App → Settings →
# Basic. Leave empty to disable Facebook sign-in (routes are only registered
# when both vars are set). Authorized redirect URIs in Meta App Dashboard MUST
# include:
#   https://hellomara.net/api/auth/facebook/callback
#   http://localhost:5000/api/auth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Payments (optional) ────────────────────────────────────────────────────
# Stripe + PayPal are feature-flagged off when these are empty.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true
PAYPAL_WEBHOOK_ID=
# Program plan IDs — create in PayPal Dashboard → Catalog → Plans
PAYPAL_PLAN_NEW_HABIT=
PAYPAL_PLAN_NEW_SKILLS=
PAYPAL_PLAN_NEW_BODY=
PAYPAL_PLAN_NEW_LIFE=
PAYPAL_PLAN_NEW_YOU=
# Frontend: PayPal Client ID exposed to browser (same as PAYPAL_CLIENT_ID)
VITE_PAYPAL_CLIENT_ID=

# ─── Web Push (VAPID) — Phase 2 P2.1.4 ─────────────────────────────────────
# Generate a keypair once with: npx web-push generate-vapid-keys
# Then set both values on Railway. The same keypair must be stable across
# deploys — rotating invalidates every existing PushSubscription in the
# browser. Leave empty to disable push (bell UI still works, just no OS
# notifications). VAPID_SUBJECT must be a mailto: URL or https:// URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hellomara.net

# ─── Launch countdown ──────────────────────────────────────────────────────
# Before LAUNCH_DATE_ISO, GET / serves public/landing.html (the pre-launch
# landing page with the countdown + waitlist). After that date, GET / falls
# through to the React SPA — no redeploy, no DNS change. Set this only if
# you need to override the default of 2026-06-01T00:00:00Z (e.g. to test).
# LAUNCH_DATE_ISO=2026-06-01T00:00:00Z

# Preview access token. Anyone visiting /preview?token=<this value> gets
# a 7-day cookie that bypasses the landing page and reaches the SPA, so
# the team can test the platform while the world sees the countdown.
# Change this to something only you know in production; the default
# below is the codebase fallback and should be considered public.
PREVIEW_TOKEN=marapreview2026

# Waitlist rate limit (POST /api/waitlist). Defaults: 5 attempts /
# IP / 15 minutes. Tune up if you launch a referral campaign.
# WAITLIST_RL_MAX=5
# WAITLIST_RL_WINDOW_MS=900000

# ─── Security — Honeypot + Tarpit + Auto-Blacklist ───────────────────────────
# Master kill-switch. Set to "false" to disable the entire system (honeypot
# routes, blacklist middleware, tarpit). Useful during debugging.
SECURITY_HONEYPOT_ENABLED=true

# Max simultaneous tarpitted connections. When reached, instant 404 instead.
# Default: 25. Prevent self-DoS under heavy scanner traffic.
SECURITY_TARPIT_MAX_CONCURRENT=25

# How many seconds to slow-drip each tarpitted connection before closing.
# Default: 20.
SECURITY_TARPIT_MAX_SECONDS=20

# Comma-separated IPs that are NEVER blacklisted (e.g. your office IP).
# Pre-seed with your own IP to guarantee admin access is never auto-banned.
SECURITY_IP_ALLOWLIST=

# Ban duration ladder per offense level (hours, comma-separated).
# Index 0 = first hit, index 1 = second hit, etc. Last value is repeated.
# Default: 1h → 6h → 24h → 7 days.
SECURITY_BAN_LADDER=1,6,24,168

# === Error tracking (Sentry) — optional ===
# When set, the backend reports unhandled errors to Sentry. Leave empty to
# disable (the app runs fine without it). Create a project at sentry.io and
# copy the DSN here.
SENTRY_DSN=
# Fraction (0..1) of transactions sampled for performance tracing. Default 0.
SENTRY_TRACES_SAMPLE_RATE=0
# Frontend DSN — read at BUILD time by Vite (must be prefixed VITE_).
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
