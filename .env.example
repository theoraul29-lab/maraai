# App runtime
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Session auth (generate a strong random string)
SESSION_SECRET=replace-with-a-long-random-secret

# Admin user IDs (comma-separated session UIDs allowed admin access)
ADMIN_USER_IDS=

# CORS Origins (comma-separated — include your Railway URL and local dev origin)
CORS_ORIGINS=https://your-app.up.railway.app,http://localhost:5173

# SQLite database path
# Railway with volume: sqlite:///data/maraai.sqlite
# Local default: sqlite:///./maraai.sqlite
DATABASE_URL=sqlite:///./maraai.sqlite

# Optional AI provider settings
GEMINI_API_KEY=

# Optional scheduler controls
PROCESS_AI_TASKS=false
