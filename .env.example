# ─── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Required in production. In dev a random one is generated if unset.
SESSION_SECRET=

# ─── Auth ───────────────────────────────────────────────────────────────────
# `local` bypasses OAuth and is the dev default. Use `oauth` only when you
# have the identity provider configured.
AUTH_MODE=local

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite path. On Railway, mount a Volume at /data and use:
#   sqlite:////data/maraai.sqlite
# Four slashes = absolute path (/data/...). Three slashes = relative to CWD.
DATABASE_URL=sqlite:///./maraai.sqlite

# ─── AI Provider (Anthropic Claude) ─────────────────────────────────────────
# Required. Get one from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional. Max output tokens per reply (default: 1024).
ANTHROPIC_MAX_TOKENS=1024

# Optional. Request timeout in ms (default: 120000).
ANTHROPIC_TIMEOUT_MS=120000

# ─── Mara Brain ─────────────────────────────────────────────────────────────
# Enable the autonomous brain cycle (learning, research, self-reflection).
# Set to "true" in production once ANTHROPIC_API_KEY is configured.
PROCESS_AI_TASKS=false

# Optional. Override the brain cycle interval (default: 2h = 7200000 ms).
# BRAIN_CYCLE_INTERVAL_MS=7200000

# ─── Mara Learning Engine ───────────────────────────────────────────────────
# Phase 4.5 of the brain cycle: per-module growth analyzers (You / Reels /
# Trading / Writers / Creators / VIP). Each analyzer proposes concrete growth
# levers that require admin approval in /admin/brain.
# Set to "false" to disable JUST the module analyzers without touching the
# rest of the brain cycle.
MARA_LEARNING_ENABLED=true

# Hard cap on Claude calls made by autonomous learning (per rolling 24h).
# User-facing chat is never throttled by this. Default: 100.
MARA_LEARNING_MAX_CALLS_PER_DAY=100

# ─── Admin access ───────────────────────────────────────────────────────────
# Comma-separated list of user ids with admin access to /admin/brain, etc.
ADMIN_USER_IDS=

# Comma-separated list of admin emails (case-insensitive). Use this in addition
# to or instead of ADMIN_USER_IDS — emails survive DB resets (ephemeral SQLite
# without a mounted Volume), so you stay admin even after a redeploy wipes
# user ids. Example: ADMIN_EMAILS=you@example.com,ops@example.com
ADMIN_EMAILS=

# ─── OAuth — Google ─────────────────────────────────────────────────────────
# Both values come from https://console.cloud.google.com/apis/credentials →
# "OAuth 2.0 Client IDs" → Web application. Leave empty to disable the
# Google sign-in button (the backend endpoint returns a redirect to
# `/?oauth_error=oauth_not_configured`).
#
# Authorized redirect URIs in Google Cloud Console MUST include, in order:
#   https://hellomara.net/api/auth/google/callback
#   http://localhost:5000/api/auth/google/callback
#   http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Override the base URL used when building the redirect_uri passed
# to Google. Defaults to the current request's origin (works behind Railway's
# reverse proxy because we honour x-forwarded-proto / x-forwarded-host).
# OAUTH_REDIRECT_BASE=https://hellomara.net

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. https://maraai.app,http://localhost:5173).
# Leave empty in dev to allow any origin.
CORS_ORIGINS=

# ─── Payments (optional) ────────────────────────────────────────────────────
# Stripe + PayPal are feature-flagged off when these are empty.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
