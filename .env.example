# App runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=5000

# Sessions (generate a long random string)
SESSION_SECRET=replace-with-a-long-random-secret

# SQLite database path
# Railway with volume: sqlite:///data/maraai.sqlite
# Local default: sqlite:///./maraai.sqlite
DATABASE_URL=sqlite:///./maraai.sqlite

# CORS — set to your Railway URL in production
CORS_ORIGINS=https://your-railway-url.railway.app

# Admin user IDs (comma-separated session UIDs)
ADMIN_USER_IDS=

# OpenRouter AI provider (replaces Gemini)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: shown in OpenRouter dashboard usage stats
OPENROUTER_HTTP_REFERER=https://your-railway-url.railway.app
OPENROUTER_X_TITLE=MaraAI

# Optional scheduler controls
MARA_LEARNING_AUTORUN=true
MARA_LEARNING_INTERVAL_HOURS=8
