# App runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=5000

# Sessions (generate a long random string)
SESSION_SECRET=replace-with-a-long-random-secret

# SQLite database path
# Three slashes = relative path (e.g. sqlite:///./foo.sqlite)
# Four slashes = absolute path (e.g. sqlite:////data/foo.sqlite)
# Railway with volume mounted at /data: sqlite:////data/maraai.sqlite
# Local default (relative to cwd): sqlite:///./maraai.sqlite
DATABASE_URL=sqlite:///./maraai.sqlite

# CORS — set to your Railway URL in production
CORS_ORIGINS=https://your-railway-url.railway.app

# Admin user IDs (comma-separated session UIDs)
ADMIN_USER_IDS=

# ─── AI Provider ────────────────────────────────────────────────────────────
# Choose which LLM backend to use.
# Default: "ollama" when OLLAMA_BASE_URL is set, otherwise "openrouter".
AI_PROVIDER=ollama

# ─── Ollama (self-hosted — recommended for Railway) ─────────────────────────
# Base URL of the Ollama service.
# Railway internal networking: http://ollama:11434
# Local: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (must be pulled on the Ollama service).
# Lightweight options: llama3.2:1b (default), phi3:mini
# On CPU-only hardware stick to 1B/small models — larger models time out.
OLLAMA_MODEL=llama3.2:1b

# Max time (ms) to wait for a single Ollama response. Default 60000.
# Raise on slow CPU Railway plans; lower if you want faster "please retry"
# fallbacks when the model is struggling.
OLLAMA_TIMEOUT_MS=60000

# Hard cap on reply tokens from Ollama. Smaller = snappier answers, but the
# model may truncate. Default 220. Raise to ~400 for long-form answers.
OLLAMA_NUM_PREDICT=220

# When Ollama fails (timeout, model not pulled, network), automatically retry
# the request on OpenRouter if OPENROUTER_API_KEY is set. Default on.
LLM_AUTO_FALLBACK=true

# ─── OpenRouter ──────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=openrouter. Also used as Ollama fallback when
# LLM_AUTO_FALLBACK=true.
OPENROUTER_API_KEY=
# Model to use via OpenRouter (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional headers for OpenRouter analytics
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=MaraAI

# ─── Legacy OpenAI-compatible endpoint (optional) ────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Autonomous brain scheduler ──────────────────────────────────────────────
# The brain is ENABLED BY DEFAULT (PR C). It runs a 10-phase learning +
# research + reflection cycle in the background and publishes self-marketing
# posts from what it learns. See server/mara-brain/manager.ts.
#
# Kill-switch: set BRAIN_ENABLED=false (or PROCESS_AI_TASKS=false) to turn
# the whole scheduler off. Useful if OpenRouter credits are low or if you
# want to reduce Railway CPU usage during an incident.
BRAIN_ENABLED=true
PROCESS_AI_TASKS=true

# Override cycle cadence (ms). Keep conservative on Railway CPU plans.
# Defaults: cycle=6h, self-post=4h, manual-trigger cooldown=5min.
# BRAIN_CYCLE_INTERVAL_MS=21600000
# BRAIN_SELF_POST_INTERVAL_MS=14400000
# BRAIN_MANUAL_COOLDOWN_MS=300000

MARA_LEARNING_AUTORUN=true
MARA_LEARNING_INTERVAL_HOURS=8

# ─── Billing / subscriptions ─────────────────────────────────────────────────
# Master switch for payment rails. Leave false until Stripe/PayPal keys are
# configured — /api/billing/subscribe returns 503 'payments_disabled' while
# this is off, but the plan catalogue and feature-gating remain active.
PAYMENTS_ENABLED=false

# Stripe (subscription mode). Required when PAYMENTS_ENABLED=true and the
# operator wants to accept card payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLIC_KEY=

# PayPal subscriptions (REST API). Required when PAYMENTS_ENABLED=true and
# the operator wants to accept PayPal.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# 'live' for production, 'sandbox' for testing. Default sandbox.
PAYPAL_MODE=sandbox
