# App runtime
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins (required in production)
# Example: CORS_ORIGINS=https://maraai-production.up.railway.app,https://yourdomain.com
CORS_ORIGINS=https://maraai-production.up.railway.app

# Sessions/auth
AUTH_MODE=local
SESSION_SECRET=replace-with-a-long-random-secret

# SQLite database path
# Railway with volume (absolute path — note the 4 slashes): sqlite:////data/maraai.sqlite
# Local default (relative path — 3 slashes + dot):          sqlite:///./maraai.sqlite
DATABASE_URL=sqlite:///./maraai.sqlite

# AI provider (optional — leave blank to disable AI features)
GEMINI_API_KEY=

# Optional: scheduler controls
PROCESS_AI_TASKS=false

