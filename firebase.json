{
  "projects": {
    "default": "maraai-488fb"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs22"
  },
  "hosting": [
    {
      "target": "maraai-488fb",
      "public": "frontend/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "*.md"
      ],
      "cleanUrls": true,
      "trailingSlash": false,
      "rewrites": [
        {
          "source": "/api/**",
          "function": {
            "functionId": "api",
            "region": "europe-west1"
          }
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/api/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        },
        {
          "source": "/**/*.@(js|css|woff2|woff|ttf|eot|svg)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "/index.html",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache, no-store, must-revalidate"
            }
          ]
        }
      ]
    }
  ],
  "dataconnect": {
    "source": "dataconnect"
  }
}
