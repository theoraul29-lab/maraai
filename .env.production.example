# Production Environment — .env.production.example
# Copiază şi completează pe Railway (Settings → Variables).
# NEVER commit fişierul real .env.production în git.

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Generează un string random de 64 de caractere
SESSION_SECRET=<GENERATE_RANDOM_64_CHAR_STRING>

# ─── Database ────────────────────────────────────────────────────────────────
# Pe Railway: montează un Volume la /data şi foloseşte calea de mai jos.
DATABASE_URL=sqlite:////data/maraai.sqlite

# ─── AI — Chat (conversaţii live cu userii) ──────────────────────────────────
# console.anthropic.com/settings/keys → "Chat" workspace
ANTHROPIC_API_KEY=<SET_IN_RAILWAY_VARS>

# ─── AI — Brain (autonom: learning, research, growth engineer) ───────────────
# console.anthropic.com/settings/keys → "Brain" workspace (key separat)
# Dacă nu e setat, brain-ul foloseşte ANTHROPIC_API_KEY ca fallback.
ANTHROPIC_BRAIN_API_KEY=<SET_IN_RAILWAY_VARS>

# Optional. Model brain — poţi alege Haiku pentru cost mai mic pe brain.
# ANTHROPIC_BRAIN_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# ─── Web Search ──────────────────────────────────────────────────────────────
# serper.dev — 2500 interogări/lună gratuite
SERPER_API_KEY=<SET_IN_RAILWAY_VARS>

# ─── Mara Brain ──────────────────────────────────────────────────────────────
PROCESS_AI_TASKS=true
MARA_LEARNING_ENABLED=true
MARA_LEARNING_MAX_CALLS_PER_DAY=100
# BRAIN_CYCLE_INTERVAL_MS=3600000

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_USER_IDS=
ADMIN_EMAILS=<your@email.com>

# ─── Auth ────────────────────────────────────────────────────────────────────
AUTH_MODE=oauth
GOOGLE_CLIENT_ID=<SET_IN_RAILWAY_VARS>
GOOGLE_CLIENT_SECRET=<SET_IN_RAILWAY_VARS>
FACEBOOK_APP_ID=<SET_IN_RAILWAY_VARS>
FACEBOOK_APP_SECRET=<SET_IN_RAILWAY_VARS>

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=<SET_IN_RAILWAY_VARS>
EMAIL_FROM=Mara <noreply@hellomara.net>
FRONTEND_URL=https://hellomara.net

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://hellomara.net,https://www.hellomara.net

# ─── Payments ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<SET_IN_RAILWAY_VARS>
STRIPE_WEBHOOK_SECRET=<SET_IN_RAILWAY_VARS>
PAYPAL_CLIENT_ID=<SET_IN_RAILWAY_VARS>
PAYPAL_CLIENT_SECRET=<SET_IN_RAILWAY_VARS>

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generează o singură dată: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=<SET_IN_RAILWAY_VARS>
VAPID_PRIVATE_KEY=<SET_IN_RAILWAY_VARS>
VAPID_SUBJECT=mailto:admin@hellomara.net

# ─── Launch ──────────────────────────────────────────────────────────────────
# LAUNCH_DATE_ISO=2026-06-01T00:00:00Z
PREVIEW_TOKEN=<CHANGE_THIS_IN_PRODUCTION>
